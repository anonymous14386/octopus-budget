<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <link rel="stylesheet" href="/theme.css">
</head>
<body class="login-page">
    <div class="login-container">
        <h1>💰 Budget Tracker</h1>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        
        <% if (mode === 'register') { %>
            <form method="POST" action="/register" id="registerForm">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required minlength="12">
                    <small style="color:#aaa;font-size:0.78rem;">12+ chars, uppercase, lowercase, number, symbol</small>
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" required minlength="12">
                </div>
                <div class="form-group">
                    <label for="inviteCode">Invite Code</label>
                    <input type="text" id="inviteCode" name="inviteCode" required placeholder="Enter your invite code">
                </div>
                <!-- CAPTCHA removed from registration -->
                <button type="submit">Register</button>
            </form>
            <div class="toggle-link">
                Already have an account? <a href="/login">Login here</a>
            </div>
        <% } else { %>
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" autocomplete="username" required autofocus>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" autocomplete="current-password" required>
            </div>
            <div class="form-group">
                <label for="totpCode">2FA Code</label>
                <input type="text" id="totpCode" inputmode="numeric" maxlength="7" autocomplete="one-time-code" style="letter-spacing:0.25em;font-size:18px;text-align:center;" placeholder="000 000">
            </div>
            <button type="button" onclick="doLogin()">Login</button>
            <div id="loginError" class="error" style="display:none"></div>
            <div class="toggle-link">
                Don't have an account? <a href="/register">Register here</a>
            </div>
        <% } %>
    </div>
</body>
<script>
async function doLogin() {
    const err = document.getElementById('loginError');
    err.style.display = 'none';
    const username = document.getElementById('username')?.value.trim();
    const password = document.getElementById('password')?.value;
    const totpCode = (document.getElementById('totpCode')?.value || '').replace(/\s/g, '');
    if (!username || !password) { err.textContent = 'Credentials or 2FA incorrect'; err.style.display = 'block'; return; }
    try {
        const r = await fetch('/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, totpCode }) });
        const data = await r.json().catch(() => ({}));
        if (r.ok && data.ok) { window.location.href = '/'; }
        else { err.textContent = data.error || 'Credentials or 2FA incorrect'; err.style.display = 'block'; }
    } catch { err.textContent = 'Connection error. Please try again.'; err.style.display = 'block'; }
}

document.addEventListener('keydown', e => { if (e.key === 'Enter' && !document.getElementById('registerForm')) doLogin(); });

document.getElementById('totpCode')?.addEventListener('input', function() {
    let v = this.value.replace(/\D/g, '').slice(0, 6);
    this.value = v.length > 3 ? v.slice(0, 3) + ' ' + v.slice(3) : v;
});

document.getElementById('registerForm')?.addEventListener('submit', function(e) {
    const pw = document.getElementById('password').value;
    const cpw = document.getElementById('confirmPassword').value;
    if (pw !== cpw) { e.preventDefault(); alert('Passwords do not match.'); return; }
    if (pw.length < 12) { e.preventDefault(); alert('Password must be at least 12 characters.'); return; }
    if (!/[A-Z]/.test(pw)) { e.preventDefault(); alert('Password must contain an uppercase letter.'); return; }
    if (!/[a-z]/.test(pw)) { e.preventDefault(); alert('Password must contain a lowercase letter.'); return; }
    if (!/[0-9]/.test(pw)) { e.preventDefault(); alert('Password must contain a number.'); return; }
    if (!/[^A-Za-z0-9]/.test(pw)) { e.preventDefault(); alert('Password must contain a symbol (!@#$% etc.).'); return; }
});
</script>
</html>
